# Optional single runtime configuration. Docker Compose starts without it.
# Copy this file to .env only when you need custom domains, ports, or secrets.
APP_PORT=8765
OMNICHANNEL_PORT=8775

# Replace these URLs with the public HTTPS addresses used by your server.
PUBLIC_BASE_URL=http://127.0.0.1:8775
OMNICHANNEL_PUBLIC_URL=http://127.0.0.1:8775
EXISTING_APP_BASE_URL=http://app:8765
ALLOWED_ORIGINS=http://127.0.0.1:8765,http://127.0.0.1:8775

POSTGRES_DB=dotcom_omnichannel
POSTGRES_USER=dotcom
POSTGRES_PASSWORD=change-this-database-password
DATABASE_URL=postgresql://dotcom:change-this-database-password@postgres:5432/dotcom_omnichannel?schema=public

# Generate strong unique values on the server. Never commit the real values.
SESSION_BRIDGE_SECRET=change-this-long-random-secret
ENCRYPTION_KEY=change-this-32-byte-base64-or-hex-key
META_WEBHOOK_VERIFY_TOKEN=change-this-verify-token
META_APP_SECRET=

META_GRAPH_API_VERSION=v20.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEST_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_PAGE_ID=

VERIFY_WEBHOOK_SIGNATURES=true
ALLOW_MOCK_ENDPOINTS=false
ALLOW_QUERY_SESSION_TOKEN=false
TRUST_PROXY=1
FORCE_HTTPS=false
ENABLE_HSTS=false
LOG_LEVEL=info
REQUEST_BODY_LIMIT=12mb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
WEBHOOK_RATE_LIMIT_MAX=2000
SEND_RATE_LIMIT_MAX=120
UPLOAD_RATE_LIMIT_MAX=60
SESSION_BRIDGE_TIMEOUT_MS=5000
SSE_TICKET_TTL_MS=60000
SHUTDOWN_TIMEOUT_MS=15000

# Private tracking service on the Mac. Use its private Tailscale HTTPS URL.
TRACKING_RPA_ENABLED=false
TRACKING_RPA_BASE_URL=
TRACKING_RPA_SHARED_SECRET=
TRACKING_RPA_TIMEOUT_MS=120000

OMNI_START_RETRY_WORKER=true
OMNI_RETRY_POLL_MS=10000
OMNI_RETRY_MAX_ATTEMPTS=3

STORAGE_DRIVER=local
OMNI_UPLOAD_ROOT=./storage/uploads
OMNI_UPLOAD_MAX_BYTES=10485760
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
